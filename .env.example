# ── Required ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=your-username
POSTGRES_PASSWORD=your-password
POSTGRES_DB=career_db

# Must match POSTGRES_USER and POSTGRES_PASSWORD above
DATABASE_URL=postgresql://your-username:your-password@localhost:5433/career_db

# Mistral AI — get your key at https://console.mistral.ai/
MISTRAL_API_KEY=your-key-here

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production

# ── Optional — additional search sources ─────────────────
# The app works without these; search will use the sources that are configured.

# France Travail (ex-Pole Emploi) — https://francetravail.io/data/api
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
